{
  "manifest_version": 3,
  "name": "Arcane-Publishing-Board",
  "version": "0.1.0",
  "description": "Manage and export SimpleOnboarding content calendar pieces by workflow status.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Arcane-Publishing-Board",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "clipboardWrite"],
  "host_permissions": ["https://new.simpleonboarding.com.au/*"]
}
